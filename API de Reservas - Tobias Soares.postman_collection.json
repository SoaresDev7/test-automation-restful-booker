          "script": {
            "exec": [
              "//Valida se a busca retorna sucesso\r",
              "pm.test(\"Status code is 200 - Busca realizada\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Valida a estrutura do JSON\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Valida se os campos obrigatórios existem\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"firstname\");\r",
              "    pm.expect(jsonData).to.have.property(\"lastname\");\r",
              "    pm.expect(jsonData).to.have.property(\"bookingdates\");\r",
              "});\r",
              "\r",
              "//Valida consistência dos dados\r",
              "pm.test(\"O sobrenome deve ser 'Soares' \", function () {\r",
              "    pm.expect(jsonData.lastname).to.eql(\"Soares\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
