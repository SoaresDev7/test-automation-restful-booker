    {
      "name": "Criar reserva",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Valida a criação\r",
              "pm.test(\"Status code is 200 - Reserva criada\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Extrai o Id da reserva\r",
              "var jsonData = pm.response.json();\r",
              "pm.environment.set(\"bookingid\", jsonData.bookingid);\r",
              "\r",
              "\r",
              "//Valida dados da reserva\r",
              "pm.test(\"Valida nome do hóspede\", function () {\r",
              "    pm.expect(jsonData.booking.firstname).to.eql(\"Tobias\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validar se o depósito doi pago\", function() {\r",
              "    pm.expect(jsonData.booking.depositpaid).to.be.true;\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
